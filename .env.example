# 环境变量配置
# 复制此文件为 .env 并填写实际值

# ===================
# 数据库配置
# ===================
DATABASE_URL=postgres://user:password@localhost:5432/xiangqi?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=xiangqi

GS_DEBUG_ENABLE=0 # 0 为关闭，1 为开启

# ===================
# Redis 配置
# ===================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===================
# JWT 配置
# ===================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY_HOURS=24

# ===================
# 服务配置
# ===================
WEB_PORT=8080
GAME_PORT=8081
GAME_SERVICE_URL=http://localhost:8081

# ===================
# AI 配置
# ===================
AI_MODEL_PATH=./models/xiangqi_net.pt
AI_DEVICE=cpu  # cpu 或 cuda

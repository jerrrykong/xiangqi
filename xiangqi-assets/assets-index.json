  "usage": {
    "import_css": "@import '@/styles/main.css' 或 <link href=\"css/main.css\">",
    "import_board": "import ChessBoard from '@/components/ChessBoard.vue'",
    "import_piece": "import ChessPiece from '@/components/ChessPiece.vue'",
    "import_icons": "import logoSvg from '@/assets/svg/ui/logo.svg'"
